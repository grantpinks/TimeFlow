# Supabase (Next.js client — Realtime, Storage, optional Supabase Auth)
# Copy to .env.local and fill in from Supabase → Project Settings → API
# Also add the same NEXT_PUBLIC_* vars in Vercel → Environment Variables

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_YOUR_KEY

# Existing: backend API for rewrites (Fastify)
# NEXT_PUBLIC_API_URL=http://localhost:3001
