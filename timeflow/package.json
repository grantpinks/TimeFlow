{
  "name": "timeflow",
  "version": "0.1.0",
  "private": true,
  "description": "TimeFlow – a cross-device productivity app that smart-schedules tasks into your calendar.",
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "apps/web",
    "packages/shared",
    "packages/scheduling"
  ],
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:packages": "cd packages/shared && npm run build && cd ../scheduling && npm run build",
    "build:web": "npm run build:packages && cd apps/web && npm run build",
    "dev": "pnpm dev:backend",
    "dev:backend": "pnpm -C apps/backend dev",
    "dev:full": "bash scripts/dev-with-ngrok.sh",
    "dev:stop": "bash scripts/dev-stop.sh",
    "dev:web": "pnpm -C apps/web dev",
    "dev:mobile": "pnpm -C apps/mobile start",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "ai:regression": "pnpm -C apps/backend ai:regression",
    "format": "pnpm -r format"
  },
  "devDependencies": {
    "typescript-eslint": "^8.52.0"
  }
}
